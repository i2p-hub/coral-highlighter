// ============================================
// Coral Comprehensive Test File
// ============================================
// Goal: exercise declarations, functions, arrays,
// input/output, assignments, operators, loops,
// comments, built-ins, and punctuation.

Function HelperNoReturn() returns nothing
   integer localCount
   float localValue
   integer array(3) localNums

   // Basic assignments
   localCount = 0
   localValue = 1.5
   localNums[0] = 10
   localNums[1] = 20
   localNums[2] = 30

   // Built-in functions
   localValue = SquareRoot(9.0)
   localValue = RaiseToPower(localValue, 2.0)
   localValue = AbsoluteValue(-15.25)

   // Random functions
   SeedRandomNumbers(7)
   localCount = RandomNumber()

   // Output variants
   Put "Helper start" to output
   Put localCount to output
   Put localValue to output with 2 decimal places

Function FtInchToCm(float numFt, float numInch) returns float numCm
   float totalInches
   totalInches = (numFt * 12.0) + numInch
   numCm = totalInches * 2.54

Function ArrayAverage(integer array(?) values, integer count) returns float avg
   integer i
   integer sum
   sum = 0

   for i = 0; i < count; i = i + 1
      sum = sum + values[i]

   avg = sum / count

Function Main() returns nothing
   // === DECLARATIONS ===
   integer x
   integer y
   integer i
   integer j
   integer total
   integer index
   integer flag
   integer array(5) userNums
   integer array(?) dynamicNums
   float price
   float taxRate
   float average
   float convertedCm
   float distance

   // === INPUT ===
   x = Get next input
   y = Get next input

   // === BASIC ASSIGNMENTS ===
   total = 0
   index = 2
   flag = -1
   price = 19.95
   taxRate = 0.0825
   distance = -12.75

   // === ARRAY SIZE AND ACCESS ===
   dynamicNums.size = 4
   dynamicNums[0] = 11
   dynamicNums[1] = 22
   dynamicNums[2] = 33
   dynamicNums[3] = 44

   userNums[0] = 5
   userNums[1] = 10
   userNums[2] = 15
   userNums[3] = 20
   userNums[4] = 25

   x = userNums[index]
   y = dynamicNums[1]
   total = userNums.size + dynamicNums.size

   // === ARITHMETIC EXPRESSIONS ===
   x = 5 + 3
   x = 10 - 4
   x = 6 * 7
   x = 12 / 3
   x = 17 % 5
   x = -(3 + 4)
   price = ((price + taxRate) * 2.0) / 3.0
   total = (userNums[0] + userNums[1]) * (userNums[2] - userNums[3])

   // === COMPARISON AND LOGICAL EXPRESSIONS ===
   if x == y
      Put "equal" to output
   elseif x != y and x < 100
      Put "not equal and small" to output
   elseif not (x <= 0) or y >= 50
      Put "logic branch" to output
   else
      Put "fallback" to output

   if (x + y) > 10
      Put "sum > 10" to output

   if x < y
      Put "x less than y" to output

   if x > y
      Put "x greater than y" to output

   // === WHILE LOOP ===
   i = 0
   while i < 3
      Put i to output
      i = i + 1

   // === FOR LOOP ===
   for j = 0; j < 5; j = j + 1
      Put userNums[j] to output

   for j = 4; j >= 0; j = j - 1
      Put dynamicNums[0] to output

   // === BUILT-IN FUNCTIONS ===
   distance = AbsoluteValue(distance)
   price = SquareRoot(144.0)
   price = RaiseToPower(price, 2.0)
   SeedRandomNumbers(123)
   flag = RandomNumber()

   // === FUNCTION CALLS ===
   HelperNoReturn()
   convertedCm = FtInchToCm(5.0, 11.0)
   average = ArrayAverage(userNums, userNums.size)

   // === OUTPUT VARIANTS ===
   Put "Coral comprehensive test" to output
   Put x to output
   Put y to output
   Put total to output
   Put convertedCm to output with 3 decimal places
   Put average to output with 1 decimal places
   Put price to output with 4 decimal places
   Put userNums.size to output
   Put dynamicNums.size to output
   Put userNums[3] to output
   Put (x + y) to output
   Put RaiseToPower(2.0, 8.0) to output with 0 decimal places

   // TODO: tagged comment for comment highlighting
   // FIXME: another tagged comment
   // NOTE: comments must be on their own line in Coral
